{
  "name": "@forsakringskassan/sass-module-importer",
  "version": "2.0.0",
  "description": "sass module importer",
  "keywords": [
    "sass",
    "importer"
  ],
  "homepage": "https://github.com/Forsakringskassan/sass-module-importer",
  "bugs": "https://github.com/Forsakringskassan/sass-module-importer/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/sass-module-importer.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/importer.d.ts",
      "default": "./dist/importer.js"
    }
  },
  "types": "./dist/importer.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsc",
    "build": "node build.mjs",
    "postbuild": "dts-bundle-generator -o dist/importer.d.ts src/importer.ts",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "lint": "run-s eslint prettier:check",
    "lint:fix": "run-s eslint:fix prettier:write",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "pretest": "npm run lint",
    "test": "vitest run"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "dependencies": {
    "resolve-package-path": "^4.0.3",
    "resolve.exports": "^2.0.3"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "3.3.10",
    "@forsakringskassan/eslint-config": "14.1.2",
    "@forsakringskassan/eslint-config-cli": "14.1.0",
    "@forsakringskassan/eslint-config-typescript": "14.1.0",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "14.1.0",
    "@forsakringskassan/eslint-config-vitest": "14.1.1",
    "@forsakringskassan/prettier-config": "3.3.6",
    "@forsakringskassan/vitest-config": "2.2.5",
    "@tsconfig/node20": "20.1.9",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "20.19.39",
    "dts-bundle-generator": "9.5.1",
    "esbuild": "0.28.0",
    "npm-pkg-lint": "4.6.4",
    "npm-run-all2": "8.0.4",
    "sass": "1.99.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  },
  "peerDependencies": {
    "sass": "^1.79.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
