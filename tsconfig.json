{
    "extends": [
        "@tsconfig/node22",
        "@tsconfig/recommended",
        "@tsconfig/strictest"
    ],
    "compilerOptions": {
        "noEmit": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "types": ["node"],
        "noImplicitAny": false,
        "noUncheckedIndexedAccess": false
    },
    "include": ["src/**/*.ts"]
}
